// ============================================================
// INTERMARKET TICK PRESSURE IMBALANCE v3 (ITPI)
// ============================================================
// Companion to: IDB v5 + CSD28 + CBES + SBPO + CPMD
//
// ARCHITECTURE: THREE-TIER REAL-TIME LEAD-LAG
// ──────────────────────────────────────────────
//   Tier 1 — Treasury Futures  (fastest, causal, LIVE)
//   Tier 2 — FX Futures        (institutional, LIVE)
//   Tier 3 — Spot FX CFD       (what you trade, slowest)
//
//   Gap 1: Bond→Spot    = tier1_vel − spot_vel  (2-8 min lead)
//   Gap 2: Futures→Spot = tier2_vel − spot_vel  (1-4 min lead)
//   Gap 3: Bond→Futures = tier1_vel − tier2_vel (earliest)
//
// WHY TREASURY FUTURES, NOT TVC BOND YIELDS:
// ──────────────────────────────────────────────
//   TVC:US10Y, TVC:DE10Y etc. are END-OF-DAY composite yields.
//   They update ONCE per day. On 1m they show the same value
//   repeated across all intraday bars — velocity is always zero
//   except at session open. That gives directional BIAS, not
//   a real-time 2-5 minute lead signal.
//
//   Treasury FUTURES (ZN1!, FGBL1!, R1!) ARE the bond market:
//   → Update every second during market hours
//   → Available at 1m on TradingView (CME/EUREX products)
//   → React to macro events within seconds
//   → Institutional desks use these to price rate expectations
//   → Lead FX spot by the documented 2-8 minutes
//
//   This is the version that actually delivers what was promised.
//
// TREASURY FUTURES — PRICE VS YIELD INVERSION:
// ──────────────────────────────────────────────
//   Bond futures price moves INVERSELY to yield:
//     Futures price UP   = bond demand up = yields DOWN
//     Futures price DOWN = bond selling   = yields UP
//
//   For FX, RISING yields = currency STRENGTHENS.
//   So for FX signals we need yield direction, not price direction.
//   We invert: bond_vel = -futures_price_vel
//
//   Example: EURUSD
//     Bund futures (FGBL1!) fall = EU yields rising = EUR strengthens
//     ZN1! futures rise = US yields falling = USD weakens
//     Combined: EUR strengthens AND USD weakens = EURUSD goes UP
//     Bond spread = (-FGBL_vel) - (-ZN_vel) = ZN_vel - FGBL_vel
//     Positive spread = EURUSD should rise ✓
//
// INSTRUMENTS USED:
// ──────────────────
//   US rates:   CBOT:ZN1!     (10Y Treasury futures)  — most liquid
//   US 2Y:      CBOT:ZT1!     (2Y Treasury futures)   — rate-sensitive
//   EU rates:   EUREX:FGBL1!  (Bund futures)
//   UK rates:   LIFFE:R1!     (Gilt futures)
//   AUS rates:  CME:6A1!      (AUD futures proxy — RBA expectations embedded)
//   CAD rates:  MONTRÉAL:CGB1! (Canadian bond futures)
//   JPY proxy:  CME:NIY1!     (Nikkei mini futures — BOJ YCC broken)
//   CHF proxy:  TVC:GOLD      (store of value — available all hours)
//               AMEX:VXX      (VIX ETF — European risk proxy for EURCHF)
//   NZD:        Use AUD proxy (CME:6A1! / ASX bond futures)
//
// SIGNAL GRADES:
//   Grade A: Treasury futures lead + FX futures lead + earliest (bond>fut)
//   Grade B: Treasury futures lead + FX futures lead
//   Grade C: Treasury futures lead only (earliest, before FX futures react)
//   Grade D: FX futures lead only (no bond confirmation)
//
// HOW TO USE:
//   1. IDB v5 fires macro signal on 15m (bond yield gate already passed)
//   2. CSD28 identifies coiled pair on 15m
//   3. Open that pair on 1m with ITPI v3
//   4. Wait for Grade A or B (treasury AND FX futures both moving)
//   5. CBES/SBPO/CPMD confirm 1m structure
//   6. Enter — stop from label
//
// BEST TIMEFRAME: 1M
// ALSO WORKS ON:  2M, 3M, 5M
// ============================================================

//@version=5
indicator(
     title      = "Intermarket Tick Pressure Imbalance v3",
     shorttitle = "ITPI v3",
     overlay    = false,
     max_labels_count = 200,
     max_lines_count  = 200
 )

// ════════════════════════════════════════════════════════════
// ── INPUTS
// ════════════════════════════════════════════════════════════
var string GRP_VEL = "Velocity Settings"
i_roc_lb     = input.int  (3,    "ROC Period (bars)",               group=GRP_VEL, minval=1, maxval=15,
     tooltip="3 bars = 3 minutes on 1m. Applied to all tiers. Treasury futures react within 1-3 bars of a macro event.")
i_smooth_lb  = input.int  (2,    "EMA Smoothing (bars)",            group=GRP_VEL, minval=1, maxval=5,
     tooltip="Smoothing on velocity. 1 = raw. 2-3 = balanced.")

var string GRP_THRESH = "Signal Thresholds"
i_bond_thresh = input.float(0.010, "Treasury Lead Threshold (%)",   group=GRP_THRESH, minval=0.001, maxval=0.200, step=0.001,
     tooltip="Min gap between treasury velocity and spot velocity. Treasury futures move ~0.01-0.05% per minute on macro events.")
i_fut_thresh  = input.float(0.010, "FX Futures Lead Threshold (%)", group=GRP_THRESH, minval=0.001, maxval=0.200, step=0.001,
     tooltip="Min gap between FX futures velocity and spot velocity.")
i_bf_thresh   = input.float(0.008, "Treasury→FX Futures Threshold",group=GRP_THRESH, minval=0.001, maxval=0.200, step=0.001,
     tooltip="Min gap between treasury and FX futures velocity. Earliest signal — treasuries moved but FX futures haven't.")
i_spot_max    = input.float(0.015, "Max Spot Velocity (closed)",    group=GRP_THRESH, minval=0.001, maxval=0.200, step=0.001,
     tooltip="If spot already moving this fast, lead-lag window closed.")

var string GRP_STOP = "Stop Settings"
i_show_stops  = input.bool (true,  "Show Auto Stop Levels",         group=GRP_STOP)
i_stop_buf    = input.float(0.3,   "Stop Buffer (× spread est)",    group=GRP_STOP, minval=0.0, maxval=2.0, step=0.1)
i_stop_timeout= input.int  (15,    "Stop Timeout (bars)",           group=GRP_STOP, minval=5, maxval=50)

var string GRP_OVER = "Manual Override"
i_use_manual  = input.bool  (false,      "Override Auto-Detection", group=GRP_OVER,
     tooltip="Manually specify treasury and futures symbols. Use for pairs not in auto-detection.")
i_bond_a_man  = input.symbol("CBOT:ZN1!",  "Treasury A (base)",    group=GRP_OVER)
i_bond_b_man  = input.symbol("CBOT:ZN1!",  "Treasury B (quote)",   group=GRP_OVER)
i_fut_man     = input.symbol("CME:6E1!",   "FX Futures",           group=GRP_OVER)
i_fut_inv_man = input.bool  (false,        "Invert FX Futures",    group=GRP_OVER)
i_ba_inv_man  = input.bool  (true,         "Invert Treasury A",    group=GRP_OVER,
     tooltip="Treasury futures price inversely related to yield. Normally invert both. Disable only for special proxies like Gold/VXX.")
i_bb_inv_man  = input.bool  (true,         "Invert Treasury B",    group=GRP_OVER)

var string GRP_DISP = "Display"
i_show_bond   = input.bool(true,  "Show Treasury Velocity",         group=GRP_DISP)
i_show_fut    = input.bool(true,  "Show FX Futures Velocity",       group=GRP_DISP)
i_show_spot   = input.bool(true,  "Show Spot Velocity",             group=GRP_DISP)
i_show_gap    = input.bool(true,  "Show Treasury-Spot Gap",         group=GRP_DISP)
i_show_labels = input.bool(true,  "Show Signal Labels",             group=GRP_DISP)
i_show_table  = input.bool(true,  "Show Live Stats Table",          group=GRP_DISP)
i_bar_color   = input.bool(true,  "Color Bars by Signal Grade",     group=GRP_DISP)

var string GRP_COL = "Colors"
i_c_bond    = input.color(#00B0FF, "Treasury",      group=GRP_COL)
i_c_fut     = input.color(#FFD600, "FX Futures",    group=GRP_COL)
i_c_spot    = input.color(#607D8B, "Spot",          group=GRP_COL)
i_c_grade_a = input.color(#00E676, "Grade A",       group=GRP_COL)
i_c_grade_b = input.color(#69FF47, "Grade B",       group=GRP_COL)
i_c_grade_c = input.color(#FFD600, "Grade C",       group=GRP_COL)
i_c_grade_d = input.color(#FF9100, "Grade D",       group=GRP_COL)
i_c_stop    = input.color(#FF6D00, "Stop",          group=GRP_COL)
i_c_target  = input.color(#00E676, "Target",        group=GRP_COL)

// ════════════════════════════════════════════════════════════
// ── SESSION DETECTION (JPY proxy switching)
// ════════════════════════════════════════════════════════════
int  bar_utc_m   = hour(time, "UTC") * 60 + minute(time, "UTC")
bool tokyo_hours = bar_utc_m >= 1260 or bar_utc_m < 420  // 21:00–07:00 UTC
bool london_ny   = not tokyo_hours

// ════════════════════════════════════════════════════════════
// ── UNCONDITIONAL DATA FETCHING
// ════════════════════════════════════════════════════════════
// ALL symbols fetched with literal strings (simple string requirement).
// Series selection done AFTER fetching using normal Pine logic.

// ── Treasury / Bond Futures (Tier 1) ─────────────────────────
// Price moves INVERSELY to yield — we invert velocity later.
// ZN1!:   US 10Y Treasury Note futures  — most liquid US rate instrument
// ZT1!:   US 2Y Treasury Note futures   — more rate-sensitive for short end
// FGBL1!: German Bund futures (10Y)     — EUR rate benchmark
// R1!:    UK Gilt futures (10Y)         — GBP rate benchmark
// CGB1!:  Canadian Government Bond fut  — CAD rate benchmark
// NIY1!:  Nikkei mini futures (CME)     — JPY proxy (BOJ YCC breaks JP bonds)
// GOLD:   Gold spot                     — CHF safe-haven proxy (no inversion needed)
// VXX:    VIX ETF (AMEX)               — European risk/CHF proxy (no inversion)
float p_zn1   = request.security("CBOT:ZN1!",      timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_zt1   = request.security("CBOT:ZT1!",      timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_bund  = request.security("EUREX:FGBL1!",   timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_gilt  = request.security("LIFFE:R1!",      timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_cgb   = request.security("MONTRÉAL:CGB1!", timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_niy   = request.security("CME:NIY1!",      timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_gold  = request.security("TVC:GOLD",        timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_vxx   = request.security("AMEX:VXX",        timeframe.period, close, lookahead=barmerge.lookahead_off)

// ── FX Futures (Tier 2) ───────────────────────────────────────
float p_6e    = request.security("CME:6E1!",        timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_6b    = request.security("CME:6B1!",        timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_6a    = request.security("CME:6A1!",        timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_6n    = request.security("CME:6N1!",        timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_6j    = request.security("CME:6J1!",        timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_6c    = request.security("CME:6C1!",        timeframe.period, close, lookahead=barmerge.lookahead_off)
float p_6s    = request.security("CME:6S1!",        timeframe.period, close, lookahead=barmerge.lookahead_off)

// ════════════════════════════════════════════════════════════
// ── VELOCITY HELPERS
// ════════════════════════════════════════════════════════════
f_roc(src, lb) =>
    src[lb] != 0.0 ? (src - src[lb]) / src[lb] * 100.0 : 0.0

f_vel(src) =>
    ta.ema(f_roc(src, i_roc_lb), i_smooth_lb)

// ── Raw velocities (price direction) ─────────────────────────
// Treasury futures: price velocity (NOT yet inverted to yield direction)
float v_zn1   = f_vel(p_zn1)    // US 10Y price vel
float v_zt1   = f_vel(p_zt1)    // US 2Y price vel
float v_bund  = f_vel(p_bund)   // Bund price vel
float v_gilt  = f_vel(p_gilt)   // Gilt price vel
float v_cgb   = f_vel(p_cgb)    // CGB price vel
float v_niy   = f_vel(p_niy)    // Nikkei fut vel (already in correct direction)
float v_gold  = f_vel(p_gold)   // Gold vel (already correct — Gold up = CHF up)
float v_vxx   = f_vel(p_vxx)    // VXX vel (already correct — VXX up = CHF up)

// FX Futures: price velocity
float v_6e    = f_vel(p_6e)
float v_6b    = f_vel(p_6b)
float v_6a    = f_vel(p_6a)
float v_6n    = f_vel(p_6n)
float v_6j    = f_vel(p_6j)
float v_6c    = f_vel(p_6c)
float v_6s    = f_vel(p_6s)

// Spot velocity
float v_spot  = f_vel(close)

// ── Yield-direction velocities (treasury futures inverted) ────
// Bond futures price DOWN = yield UP = currency STRENGTHENS
// So: yield_vel = -price_vel
// Gold and VXX are NOT inverted — they move in same direction as CHF/JPY
float yv_us10  = -v_zn1    // US 10Y yield vel: ZN up = yield down = USD weakens
float yv_us02  = -v_zt1    // US 2Y yield vel
float yv_eur   = -v_bund   // EUR yield vel: Bund up = EU yield down = EUR weakens
float yv_gbp   = -v_gilt   // GBP yield vel
float yv_cad   = -v_cgb    // CAD yield vel
float yv_jpy   = v_niy     // Nikkei: UP = risk on = JPY weakens = correct direction
float yv_chf_g = v_gold    // Gold: UP = CHF strengthens = correct direction
float yv_chf_v = v_vxx     // VXX: UP = CHF strengthens = correct direction

// ── JPY yield proxy: session-aware series selection ───────────
// Tokyo hours: Nikkei futures (NIY1!) — risk/carry proxy
// London/NY:   Base currency yield velocity (rate differential)
// This is a SERIES selection — legal in Pine v5

// ════════════════════════════════════════════════════════════
// ── PER-PAIR TREASURY SPREAD & FX FUTURES VELOCITY
// ════════════════════════════════════════════════════════════
// treasury_spread_vel = base_yield_vel - quote_yield_vel
//   Positive = base currency rates rising faster than quote
//            = base currency strengthening = pair goes UP
//
// fx_fut_vel = FX futures velocity (sign-adjusted per pair)
//   Positive = pair going UP
//
// Both computed as series using already-fetched prices.
// No dynamic symbol switching — Pine v5 compliant.

string tk = syminfo.ticker

// treasury_a = base currency yield velocity
// treasury_b = quote currency yield velocity
// treasury_spread = treasury_a - treasury_b (positive = pair goes up)
// fx_fut = FX futures velocity (adjusted direction)

float treasury_a  = na
float treasury_b  = na
float fx_fut      = na
string ta_label   = ""
string tb_label   = ""
string fut_label  = ""

// ── JPY proxy per pair (session-aware) ───────────────────────
// During Tokyo: NIY1! (Nikkei futures vel = JPY weakness direction)
// During LN/NY: base currency yield vel (rate differential dominates)
// Both move in SAME direction as the pair (JPY weakens = pair rises)
// so no sign inversion needed for the JPY component

switch tk
    // ── USD Majors ───────────────────────────────────────────
    "EURUSD" =>
        treasury_a := yv_eur    // EUR yield up = EUR strong = EURUSD up
        treasury_b := yv_us10   // USD yield up = USD strong = EURUSD down
        fx_fut     := v_6e      // 6E1! up = EURUSD up
        ta_label   := "FGBL(EUR)"
        tb_label   := "ZN(USD)"
        fut_label  := "6E1!"

    "GBPUSD" =>
        treasury_a := yv_gbp
        treasury_b := yv_us10
        fx_fut     := v_6b
        ta_label   := "R1!(GBP)"
        tb_label   := "ZN(USD)"
        fut_label  := "6B1!"

    "AUDUSD" =>
        // AUD: no liquid AUS bond futures on TradingView for most users
        // Use 6A1! velocity as AUD rate proxy — it captures RBA expectations
        // Australian 10Y: ASX:XT1! (may not be available on all plans)
        // Fallback: use -ZN1! as the USD component (inverted) as spread
        // Best available: treat 6A1! as treasury proxy for AUD
        treasury_a := v_6a      // 6A1! vel = AUD direction (proxy for AU rates)
        treasury_b := yv_us10   // ZN1! inverted = USD yield
        fx_fut     := v_6a      // same — 6A1! IS the most institutional AUD instrument
        ta_label   := "6A(AUD proxy)"
        tb_label   := "ZN(USD)"
        fut_label  := "6A1!"

    "NZDUSD" =>
        // NZD: use 6A1! as proxy (AUD/NZD highly correlated)
        treasury_a := v_6a
        treasury_b := yv_us10
        fx_fut     := v_6n
        ta_label   := "6A(NZD proxy)"
        tb_label   := "ZN(USD)"
        fut_label  := "6N1!"

    "USDCAD" =>
        treasury_a := yv_us10   // USD yield up = USD strong = USDCAD up
        treasury_b := yv_cad    // CAD yield up = CAD strong = USDCAD down
        fx_fut     := -v_6c     // 6C1! = CAD futures; up = CAD strong = USDCAD DOWN → invert
        ta_label   := "ZN(USD)"
        tb_label   := "CGB(CAD)"
        fut_label  := "6C1!(inv)"

    "USDCHF" =>
        treasury_a := yv_us10
        treasury_b := yv_chf_g  // Gold vel: gold up = CHF strong = USDCHF down
        fx_fut     := -v_6s     // 6S1! = CHF futures; up = CHF strong = USDCHF DOWN → invert
        ta_label   := "ZN(USD)"
        tb_label   := "Gold(CHF)"
        fut_label  := "6S1!(inv)"

    "USDJPY" =>
        // USDJPY: USD yield minus JPY proxy
        // Tokyo: NIY1! up = Nikkei up = risk on = JPY weakens = USDJPY up → ADD to spread
        // LN/NY: ZT1! (US 2Y) up = US yield up = USDJPY up → ADD to spread
        // Both JPY proxies ADD (not subtract) from the USD side
        float jpy_tokyo = yv_jpy    // NIY1! vel: up = JPY weak = USDJPY up
        float jpy_lnny  = yv_us02   // ZT1! vel: US 2Y up = USDJPY up (same direction as USD)
        // treasury_spread = USD_component + JPY_weakness_component
        // When USD rates up AND JPY proxy up → double bull signal
        treasury_a := yv_us10
        treasury_b := -(tokyo_hours ? jpy_tokyo : jpy_lnny)  // negate to make subtraction work
        fx_fut     := -v_6j     // 6J1! = JPY futures; up = JPY strong = USDJPY DOWN → invert
        ta_label   := "ZN(USD)"
        tb_label   := tokyo_hours ? "NIY(JPY)" : "ZT(USD2Y)"
        fut_label  := "6J1!(inv)"

    // ── EUR Crosses ──────────────────────────────────────────
    "EURGBP" =>
        treasury_a := yv_eur
        treasury_b := yv_gbp
        fx_fut     := v_6e      // 6E1! as EUR proxy (most liquid EUR instrument)
        ta_label   := "FGBL(EUR)"
        tb_label   := "R1!(GBP)"
        fut_label  := "6E1!"

    "EURJPY" =>
        float jpy_t = -(tokyo_hours ? yv_jpy : yv_us10)  // JPY weakness component
        treasury_a := yv_eur
        treasury_b := jpy_t
        fx_fut     := v_6e
        ta_label   := "FGBL(EUR)"
        tb_label   := tokyo_hours ? "NIY(JPY)" : "ZN≈JPY"
        fut_label  := "6E1!"

    "EURAUD" =>
        treasury_a := yv_eur
        treasury_b := v_6a      // AUD: 6A1! proxy
        fx_fut     := v_6e
        ta_label   := "FGBL(EUR)"
        tb_label   := "6A(AUD)"
        fut_label  := "6E1!"

    "EURCAD" =>
        treasury_a := yv_eur
        treasury_b := yv_cad
        fx_fut     := v_6e
        ta_label   := "FGBL(EUR)"
        tb_label   := "CGB(CAD)"
        fut_label  := "6E1!"

    "EURCHF" =>
        treasury_a := yv_eur
        treasury_b := yv_chf_v  // VXX: European risk proxy for EURCHF
        fx_fut     := v_6e
        ta_label   := "FGBL(EUR)"
        tb_label   := "VXX(CHF)"
        fut_label  := "6E1!"

    "EURNZD" =>
        treasury_a := yv_eur
        treasury_b := v_6a      // AUD as NZD proxy
        fx_fut     := v_6e
        ta_label   := "FGBL(EUR)"
        tb_label   := "6A(NZD)"
        fut_label  := "6E1!"

    // ── GBP Crosses ──────────────────────────────────────────
    "GBPJPY" =>
        float jpy_g = -(tokyo_hours ? yv_jpy : yv_us10)
        treasury_a := yv_gbp
        treasury_b := jpy_g
        fx_fut     := v_6b
        ta_label   := "R1!(GBP)"
        tb_label   := tokyo_hours ? "NIY(JPY)" : "ZN≈JPY"
        fut_label  := "6B1!"

    "GBPAUD" =>
        treasury_a := yv_gbp
        treasury_b := v_6a
        fx_fut     := v_6b
        ta_label   := "R1!(GBP)"
        tb_label   := "6A(AUD)"
        fut_label  := "6B1!"

    "GBPCAD" =>
        treasury_a := yv_gbp
        treasury_b := yv_cad
        fx_fut     := v_6b
        ta_label   := "R1!(GBP)"
        tb_label   := "CGB(CAD)"
        fut_label  := "6B1!"

    "GBPCHF" =>
        treasury_a := yv_gbp
        treasury_b := yv_chf_v
        fx_fut     := v_6b
        ta_label   := "R1!(GBP)"
        tb_label   := "VXX(CHF)"
        fut_label  := "6B1!"

    "GBPNZD" =>
        treasury_a := yv_gbp
        treasury_b := v_6a
        fx_fut     := v_6b
        ta_label   := "R1!(GBP)"
        tb_label   := "6A(NZD)"
        fut_label  := "6B1!"

    // ── AUD Crosses ──────────────────────────────────────────
    "AUDJPY" =>
        float jpy_a = -(tokyo_hours ? yv_jpy : v_6a)
        treasury_a := v_6a
        treasury_b := jpy_a
        fx_fut     := v_6a
        ta_label   := "6A(AUD)"
        tb_label   := tokyo_hours ? "NIY(JPY)" : "6A≈JPY"
        fut_label  := "6A1!"

    "AUDCAD" =>
        treasury_a := v_6a
        treasury_b := yv_cad
        fx_fut     := v_6a
        ta_label   := "6A(AUD)"
        tb_label   := "CGB(CAD)"
        fut_label  := "6A1!"

    "AUDCHF" =>
        treasury_a := v_6a
        treasury_b := yv_chf_g
        fx_fut     := v_6a
        ta_label   := "6A(AUD)"
        tb_label   := "Gold(CHF)"
        fut_label  := "6A1!"

    "AUDNZD" =>
        // Both AUD and NZD use same proxy → spread near zero
        // Run on futures spread only
        treasury_a := v_6a
        treasury_b := v_6n
        fx_fut     := v_6a - v_6n   // synthetic futures spread
        ta_label   := "6A(AUD)"
        tb_label   := "6N(NZD)"
        fut_label  := "6A-6N spread"

    // ── NZD Crosses ──────────────────────────────────────────
    "NZDJPY" =>
        float jpy_n = -(tokyo_hours ? yv_jpy : v_6n)
        treasury_a := v_6n
        treasury_b := jpy_n
        fx_fut     := v_6n
        ta_label   := "6N(NZD)"
        tb_label   := tokyo_hours ? "NIY(JPY)" : "6N≈JPY"
        fut_label  := "6N1!"

    "NZDCAD" =>
        treasury_a := v_6n
        treasury_b := yv_cad
        fx_fut     := v_6n
        ta_label   := "6N(NZD)"
        tb_label   := "CGB(CAD)"
        fut_label  := "6N1!"

    "NZDCHF" =>
        treasury_a := v_6n
        treasury_b := yv_chf_g
        fx_fut     := v_6n
        ta_label   := "6N(NZD)"
        tb_label   := "Gold(CHF)"
        fut_label  := "6N1!"

    // ── CAD Crosses ──────────────────────────────────────────
    "CADJPY" =>
        float jpy_c = -(tokyo_hours ? yv_jpy : yv_cad)
        treasury_a := yv_cad
        treasury_b := jpy_c
        fx_fut     := v_6c
        ta_label   := "CGB(CAD)"
        tb_label   := tokyo_hours ? "NIY(JPY)" : "CGB≈JPY"
        fut_label  := "6C1!"

    "CADCHF" =>
        treasury_a := yv_cad
        treasury_b := yv_chf_g
        fx_fut     := v_6c
        ta_label   := "CGB(CAD)"
        tb_label   := "Gold(CHF)"
        fut_label  := "6C1!"

    // ── CHF Crosses ──────────────────────────────────────────
    "CHFJPY" =>
        // Both safe havens — Gold vs Nikkei (or Gold vs Gold = 0)
        // Use Gold (CHF) vs NIY (JPY risk proxy)
        // CHFJPY up = CHF strengthening vs JPY = Gold up AND NIY down
        treasury_a := yv_chf_g  // Gold up = CHF strong = CHFJPY up
        treasury_b := -(yv_jpy) // NIY up = JPY weak = CHFJPY up → invert to make subtraction correct
        fx_fut     := -v_6j     // 6J1! up = JPY strong = CHFJPY DOWN → invert
        ta_label   := "Gold(CHF)"
        tb_label   := "NIY(JPY inv)"
        fut_label  := "6J1!(inv)"

    // ── Fallback (manual override or unrecognised) ────────────
    =>
        treasury_a := yv_us10
        treasury_b := yv_us10   // spread = 0, futures only
        fx_fut     := v_6e
        ta_label   := "ZN (fallback)"
        tb_label   := "ZN (fallback)"
        fut_label  := "6E1!"

// ── Manual override replaces pair-detected values ────────────
float bond_a_raw = i_use_manual ?
     f_vel(request.security(i_bond_a_man, timeframe.period, close, lookahead=barmerge.lookahead_off)) :
     treasury_a
float bond_b_raw = i_use_manual ?
     f_vel(request.security(i_bond_b_man, timeframe.period, close, lookahead=barmerge.lookahead_off)) :
     treasury_b
float fut_raw_man = i_use_manual ?
     f_vel(request.security(i_fut_man,    timeframe.period, close, lookahead=barmerge.lookahead_off)) :
     fx_fut

float bond_a_vel = i_use_manual ? (i_ba_inv_man ? -bond_a_raw : bond_a_raw) : bond_a_raw
float bond_b_vel = i_use_manual ? (i_bb_inv_man ? -bond_b_raw : bond_b_raw) : bond_b_raw
float fut_vel    = i_use_manual ? (i_fut_inv_man ? -fut_raw_man : fut_raw_man) : fut_raw_man

// ── Treasury spread velocity ──────────────────────────────────
// treasury_spread = treasury_a_vel - treasury_b_vel
// Positive = base ccy rates rising faster = pair goes up
// Already correctly signed in the switch above
float treasury_spread_vel = bond_a_vel - bond_b_vel
float spot_vel            = f_vel(close)

// ════════════════════════════════════════════════════════════
// ── LEAD-LAG GAPS
// ════════════════════════════════════════════════════════════
// bond_lead:     treasury ahead of spot
// fut_lead:      FX futures ahead of spot
// bond_fut_lead: treasury ahead of FX futures (earliest signal)

float bond_lead     = treasury_spread_vel - spot_vel
float fut_lead      = fut_vel             - spot_vel
float bond_fut_lead = treasury_spread_vel - fut_vel

bool spot_caught_up = math.abs(spot_vel) > i_spot_max

// ════════════════════════════════════════════════════════════
// ── GRADE SYSTEM
// ════════════════════════════════════════════════════════════
// Bull = long signal (pair going up)
bool bull_bond = bond_lead     >  i_bond_thresh and not spot_caught_up
bool bull_fut  = fut_lead      >  i_fut_thresh  and not spot_caught_up
bool bull_bf   = bond_fut_lead >  i_bf_thresh

bool bull_a = bull_bond and bull_fut and bull_bf
bool bull_b = bull_bond and bull_fut and not bull_bf
bool bull_c = bull_bond and not bull_fut
bool bull_d = bull_fut  and not bull_bond

// Bear = short signal (pair going down)
bool bear_bond = bond_lead     < -i_bond_thresh and not spot_caught_up
bool bear_fut  = fut_lead      < -i_fut_thresh  and not spot_caught_up
bool bear_bf   = bond_fut_lead < -i_bf_thresh

bool bear_a = bear_bond and bear_fut and bear_bf
bool bear_b = bear_bond and bear_fut and not bear_bf
bool bear_c = bear_bond and not bear_fut
bool bear_d = bear_fut  and not bear_bond

bool any_bull = bull_a or bull_b or bull_c or bull_d
bool any_bear = bear_a or bear_b or bear_c or bear_d
bool any_sig  = any_bull or any_bear

// ── First-bar detection ───────────────────────────────────────
bool new_bull_a = bull_a and not bull_a[1]
bool new_bull_b = bull_b and not bull_b[1] and not bull_a
bool new_bull_c = bull_c and not bull_c[1] and not bull_a and not bull_b
bool new_bull_d = bull_d and not bull_d[1] and not bull_a and not bull_b

bool new_bear_a = bear_a and not bear_a[1]
bool new_bear_b = bear_b and not bear_b[1] and not bear_a
bool new_bear_c = bear_c and not bear_c[1] and not bear_a and not bear_b
bool new_bear_d = bear_d and not bear_d[1] and not bear_a and not bear_b

bool new_bull = new_bull_a or new_bull_b or new_bull_c or new_bull_d
bool new_bear = new_bear_a or new_bear_b or new_bear_c or new_bear_d

// ════════════════════════════════════════════════════════════
// ── STOP AUTO-CALCULATION
// ════════════════════════════════════════════════════════════
float spread_est = ta.atr(3) * 0.1 * i_stop_buf

var float active_stop_long    = na
var float active_stop_short   = na
var float active_tgt_long     = na
var float active_tgt_short    = na
var int   stop_bar_long       = 0
var int   stop_bar_short      = 0
var string grade_long         = ""
var string grade_short        = ""

if new_bull
    active_stop_long  := low - spread_est
    active_stop_short := na
    stop_bar_long     := bar_index
    float sd          = close - active_stop_long
    active_tgt_long   := close + sd * 2.0
    active_tgt_short  := na
    grade_long        := new_bull_a ? "A" : new_bull_b ? "B" :
                         new_bull_c ? "C" : "D"

if new_bear
    active_stop_short := high + spread_est
    active_stop_long  := na
    stop_bar_short    := bar_index
    float sd          = active_stop_short - close
    active_tgt_short  := close - sd * 2.0
    active_tgt_long   := na
    grade_short       := new_bear_a ? "A" : new_bear_b ? "B" :
                         new_bear_c ? "C" : "D"

// Auto-clear
if not na(active_stop_long)
    bool hit      = low  < active_stop_long
    bool timeout  = bar_index > stop_bar_long  + i_stop_timeout
    bool reversed = treasury_spread_vel < -i_bond_thresh * 0.5
    if hit or timeout or reversed
        active_stop_long := na
        active_tgt_long  := na

if not na(active_stop_short)
    bool hit      = high > active_stop_short
    bool timeout  = bar_index > stop_bar_short + i_stop_timeout
    bool reversed = treasury_spread_vel >  i_bond_thresh * 0.5
    if hit or timeout or reversed
        active_stop_short := na
        active_tgt_short  := na

// ════════════════════════════════════════════════════════════
// ── REFERENCE LINES
// ════════════════════════════════════════════════════════════
hline(0,              "Zero",      color=color.new(color.white, 45), linewidth=1)
hline( i_bond_thresh, "+Tsy Thr",  color=color.new(i_c_bond, 60),   linestyle=hline.style_dashed)
hline(-i_bond_thresh, "-Tsy Thr",  color=color.new(i_c_bond, 60),   linestyle=hline.style_dashed)
hline( i_fut_thresh,  "+Fut Thr",  color=color.new(i_c_fut,  65),   linestyle=hline.style_dotted)
hline(-i_fut_thresh,  "-Fut Thr",  color=color.new(i_c_fut,  65),   linestyle=hline.style_dotted)

// ════════════════════════════════════════════════════════════
// ── VELOCITY PLOTS
// ════════════════════════════════════════════════════════════
// Spot: thin gray baseline
plot(i_show_spot ? spot_vel : na,
     "Spot", color=color.new(i_c_spot, 20), linewidth=1)

// FX Futures: medium yellow
fut_col = fut_vel >  i_fut_thresh ? color.new(i_c_fut, 0)  :
          fut_vel < -i_fut_thresh ? color.new(i_c_fut, 0)  :
                                    color.new(i_c_fut, 55)
plot(i_show_fut ? fut_vel : na,
     "FX Futures", color=fut_col, linewidth=2)

// Treasury spread: thick blue — the primary leading series
tsy_col = treasury_spread_vel >  i_bond_thresh ? color.new(i_c_bond, 0)  :
          treasury_spread_vel < -i_bond_thresh ? color.new(i_c_bond, 0)  :
                                                  color.new(i_c_bond, 55)
plot(i_show_bond ? treasury_spread_vel : na,
     "Treasury Spread", color=tsy_col, linewidth=3)

// ── Gap histogram: treasury lead over spot ────────────────────
gap_col = bond_lead >  i_bond_thresh ? color.new(i_c_grade_a, 25) :
          bond_lead < -i_bond_thresh ? color.new(i_c_grade_a, 25) :
                                       color.new(color.gray,  75)
plot(i_show_gap ? bond_lead : na,
     "Treasury-Spot Gap", color=gap_col, linewidth=2, style=plot.style_histogram)

// ════════════════════════════════════════════════════════════
// ── BACKGROUND: SIGNAL GRADE
// ════════════════════════════════════════════════════════════
grade_bg =
     (bull_a or bear_a) ? color.new(i_c_grade_a, 87) :
     (bull_b or bear_b) ? color.new(i_c_grade_b, 89) :
     (bull_c or bear_c) ? color.new(i_c_grade_c, 91) :
     (bull_d or bear_d) ? color.new(i_c_grade_d, 93) :
     na
bgcolor(grade_bg, title="Signal Grade")

// ════════════════════════════════════════════════════════════
// ── SIGNAL MARKERS
// ════════════════════════════════════════════════════════════
plotshape((new_bull_a or new_bull_b) ? treasury_spread_vel : na,
     "Bull A/B", style=shape.triangleup, location=location.absolute,
     color=i_c_grade_a, size=size.normal)
plotshape(new_bull_c ? treasury_spread_vel : na,
     "Bull C",   style=shape.triangleup, location=location.absolute,
     color=i_c_grade_c, size=size.small)
plotshape(new_bull_d ? fut_vel : na,
     "Bull D",   style=shape.triangleup, location=location.absolute,
     color=i_c_grade_d, size=size.small)

plotshape((new_bear_a or new_bear_b) ? treasury_spread_vel : na,
     "Bear A/B", style=shape.triangledown, location=location.absolute,
     color=i_c_grade_a, size=size.normal)
plotshape(new_bear_c ? treasury_spread_vel : na,
     "Bear C",   style=shape.triangledown, location=location.absolute,
     color=i_c_grade_c, size=size.small)
plotshape(new_bear_d ? fut_vel : na,
     "Bear D",   style=shape.triangledown, location=location.absolute,
     color=i_c_grade_d, size=size.small)

// ════════════════════════════════════════════════════════════
// ── BAR COLORING
// ════════════════════════════════════════════════════════════
bar_col =
     (bull_a or bear_a) ? i_c_grade_a                       :
     (bull_b or bear_b) ? i_c_grade_b                       :
     (bull_c or bear_c) ? color.new(i_c_grade_c, 30)        :
     (bull_d or bear_d) ? color.new(i_c_grade_d, 40)        :
     na
barcolor(i_bar_color ? bar_col : na, title="Grade Bars")

// ════════════════════════════════════════════════════════════
// ── STOP & TARGET — DATA WINDOW
// ════════════════════════════════════════════════════════════
plot(not na(active_stop_long)   ? active_stop_long   : na,
     "Stop Long",   color=i_c_stop,   display=display.data_window + display.status_line)
plot(not na(active_stop_short)  ? active_stop_short  : na,
     "Stop Short",  color=i_c_stop,   display=display.data_window + display.status_line)
plot(not na(active_tgt_long)    ? active_tgt_long    : na,
     "Target Long", color=i_c_target, display=display.data_window + display.status_line)
plot(not na(active_tgt_short)   ? active_tgt_short   : na,
     "Target Short",color=i_c_target, display=display.data_window + display.status_line)

// ════════════════════════════════════════════════════════════
// ── SIGNAL LABELS
// ════════════════════════════════════════════════════════════
f_pip_str(val) =>
    float pip = syminfo.mintick * 10
    str.tostring(math.round(val / pip, 1)) + "p"

f_grade_desc(g) =>
    g == "A" ? "Treasury + Futures + Early" :
    g == "B" ? "Treasury + Futures" :
    g == "C" ? "Treasury only (earliest)" :
               "Futures only"

if i_show_labels and new_bull
    string g   = grade_long
    color  lc  = g == "A" ? i_c_grade_a : g == "B" ? i_c_grade_b :
                 g == "C" ? i_c_grade_c : i_c_grade_d
    float  sd  = not na(active_stop_long) ? close - active_stop_long : na
    label.new(
         bar_index, treasury_spread_vel + i_bond_thresh * 0.3,
         "▲ LONG  [Grade " + g + "]\n" +
         f_grade_desc(g) + "\n" +
         "Tsy spread: +" + str.tostring(math.round(bond_lead,    4)) + "%\n" +
         "Fut lead:   +" + str.tostring(math.round(fut_lead,     4)) + "%\n" +
         "Tsy→Fut:    +" + str.tostring(math.round(bond_fut_lead,4)) + "%\n" +
         "Spot vel:    " + str.tostring(math.round(spot_vel,     4)) + "%\n" +
         "Tsy A: " + ta_label + "\n" +
         "Tsy B: " + tb_label + "\n" +
         "Fut:   " + fut_label + "\n" +
         (not na(sd) ? "Stop:  " + str.tostring(active_stop_long, format.mintick) +
         " (−" + f_pip_str(sd) + ")\n" +
         "T1 2:1:" + str.tostring(active_tgt_long,  format.mintick) +
         " (+" + f_pip_str(sd * 2) + ")" : "Stop: calculating..."),
         style    = label.style_label_up,
         color    = color.new(lc, 5),
         textcolor = color.black,
         size     = size.normal)

if i_show_labels and new_bear
    string g   = grade_short
    color  lc  = g == "A" ? i_c_grade_a : g == "B" ? i_c_grade_b :
                 g == "C" ? i_c_grade_c : i_c_grade_d
    float  sd  = not na(active_stop_short) ? active_stop_short - close : na
    label.new(
         bar_index, treasury_spread_vel - i_bond_thresh * 0.3,
         "▼ SHORT [Grade " + g + "]\n" +
         f_grade_desc(g) + "\n" +
         "Tsy spread: " + str.tostring(math.round(bond_lead,    4)) + "%\n" +
         "Fut lead:   " + str.tostring(math.round(fut_lead,     4)) + "%\n" +
         "Tsy→Fut:    " + str.tostring(math.round(bond_fut_lead,4)) + "%\n" +
         "Spot vel:    " + str.tostring(math.round(spot_vel,     4)) + "%\n" +
         "Tsy A: " + ta_label + "\n" +
         "Tsy B: " + tb_label + "\n" +
         "Fut:   " + fut_label + "\n" +
         (not na(sd) ? "Stop:  " + str.tostring(active_stop_short, format.mintick) +
         " (+" + f_pip_str(sd) + ")\n" +
         "T1 2:1:" + str.tostring(active_tgt_short, format.mintick) +
         " (−" + f_pip_str(sd * 2) + ")" : "Stop: calculating..."),
         style    = label.style_label_down,
         color    = color.new(lc, 5),
         textcolor = color.black,
         size     = size.normal)

// ════════════════════════════════════════════════════════════
// ── LIVE STATS TABLE
// ════════════════════════════════════════════════════════════
if i_show_table and barstate.islast
    var table tbl = table.new(
         position.top_right, 2, 20,
         bgcolor      = color.new(color.black, 80),
         border_width = 1, border_color = color.new(color.white, 60),
         frame_width  = 1, frame_color  = color.new(color.white, 40))

    HDR  = color.new(color.gray,  40)
    TXT  = color.new(color.white, 10)
    DIM  = color.new(color.white, 55)
    SML  = size.small
    TINY = size.tiny

    // Header
    table.cell(tbl, 0, 0, "ITPI v3",     bgcolor=HDR, text_color=TXT, text_size=SML)
    table.cell(tbl, 1, 0, tk,            bgcolor=HDR, text_color=TXT, text_size=SML)

    // Instruments
    table.cell(tbl, 0, 1, "── SOURCES ──", text_color=color.new(i_c_bond,0), text_size=TINY)
    table.cell(tbl, 1, 1, "", text_size=TINY)

    table.cell(tbl, 0, 2, "Tsy A",  text_color=DIM, text_size=TINY)
    table.cell(tbl, 1, 2, ta_label, text_color=color.new(i_c_bond, 10), text_size=TINY)

    table.cell(tbl, 0, 3, "Tsy B",  text_color=DIM, text_size=TINY)
    table.cell(tbl, 1, 3, tb_label, text_color=color.new(i_c_bond, 30), text_size=TINY)

    table.cell(tbl, 0, 4, "FX Fut", text_color=DIM, text_size=TINY)
    table.cell(tbl, 1, 4, fut_label, text_color=color.new(i_c_fut, 10), text_size=TINY)

    // Session (JPY pairs)
    bool jpy_pair = str.contains(tk, "JPY")
    if jpy_pair
        table.cell(tbl, 0, 5, "Session", text_color=DIM, text_size=TINY)
        table.cell(tbl, 1, 5,
             tokyo_hours ? "Tokyo (NIY1!)" : "London/NY (yield)",
             text_color=tokyo_hours ? color.new(color.orange,0) : color.new(color.blue,0),
             text_size=TINY)
    else
        table.cell(tbl, 0, 5, "", text_size=TINY)
        table.cell(tbl, 1, 5, "", text_size=TINY)

    // Velocities
    table.cell(tbl, 0, 6, "── VELOCITY ──", text_color=color.new(i_c_bond,0), text_size=TINY)
    table.cell(tbl, 1, 6, "", text_size=TINY)

    f_vc(v) =>
        v > 0.001  ? color.new(color.lime, 0) :
        v < -0.001 ? color.new(color.red,  0) :
        color.new(color.gray, 30)

    table.cell(tbl, 0, 7, "Tsy Sprd", text_color=DIM, text_size=SML)
    table.cell(tbl, 1, 7,
         (treasury_spread_vel > 0 ? "+" : "") +
         str.tostring(math.round(treasury_spread_vel, 4)) + "%",
         text_color=f_vc(treasury_spread_vel), text_size=SML)

    table.cell(tbl, 0, 8, "FX Fut",  text_color=DIM, text_size=SML)
    table.cell(tbl, 1, 8,
         (fut_vel > 0 ? "+" : "") +
         str.tostring(math.round(fut_vel, 4)) + "%",
         text_color=f_vc(fut_vel), text_size=SML)

    table.cell(tbl, 0, 9, "Spot",    text_color=DIM, text_size=SML)
    table.cell(tbl, 1, 9,
         (spot_vel > 0 ? "+" : "") +
         str.tostring(math.round(spot_vel, 4)) + "%",
         text_color=f_vc(spot_vel), text_size=SML)

    // Gaps
    table.cell(tbl, 0, 10, "── GAPS ──", text_color=color.new(i_c_grade_a,0), text_size=TINY)
    table.cell(tbl, 1, 10, "", text_size=TINY)

    f_gc(gap, thr) =>
        math.abs(gap) > thr     ? color.new(color.lime,   0) :
        math.abs(gap) > thr*0.5 ? color.new(color.yellow, 0) :
        color.new(color.gray, 40)

    table.cell(tbl, 0, 11, "Tsy→Spot", text_color=DIM, text_size=SML)
    table.cell(tbl, 1, 11,
         (bond_lead > 0 ? "+" : "") + str.tostring(math.round(bond_lead, 4)) + "%",
         text_color=f_gc(bond_lead, i_bond_thresh), text_size=SML)

    table.cell(tbl, 0, 12, "Fut→Spot", text_color=DIM, text_size=SML)
    table.cell(tbl, 1, 12,
         (fut_lead > 0 ? "+" : "") + str.tostring(math.round(fut_lead, 4)) + "%",
         text_color=f_gc(fut_lead, i_fut_thresh), text_size=SML)

    table.cell(tbl, 0, 13, "Tsy→Fut",  text_color=DIM, text_size=SML)
    table.cell(tbl, 1, 13,
         (bond_fut_lead > 0 ? "+" : "") + str.tostring(math.round(bond_fut_lead, 4)) + "%",
         text_color=f_gc(bond_fut_lead, i_bf_thresh), text_size=SML)

    // Signal
    string cur_grade =
         (bull_a or bear_a) ? "A — Tsy + Fut + Early" :
         (bull_b or bear_b) ? "B — Tsy + Futures"     :
         (bull_c or bear_c) ? "C — Treasury (earliest)":
         (bull_d or bear_d) ? "D — Futures only"       : "—"
    string cur_dir =
         any_bull ? "▲ LONG"  :
         any_bear ? "▼ SHORT" : "—"
    color cur_col =
         (bull_a or bear_a) ? i_c_grade_a :
         (bull_b or bear_b) ? i_c_grade_b :
         (bull_c or bear_c) ? i_c_grade_c :
         (bull_d or bear_d) ? i_c_grade_d : DIM

    sig_hdr = any_sig ? color.new(cur_col, 50) : HDR
    table.cell(tbl, 0, 14, "SIGNAL", bgcolor=sig_hdr, text_color=TXT, text_size=SML)
    table.cell(tbl, 1, 14, cur_dir,  bgcolor=sig_hdr, text_color=cur_col, text_size=SML)

    table.cell(tbl, 0, 15, "Grade",   text_color=DIM,     text_size=SML)
    table.cell(tbl, 1, 15, cur_grade, text_color=cur_col, text_size=SML)

    // Stop/Target
    table.cell(tbl, 0, 16, "──────", text_color=color.new(color.white,70), text_size=TINY)
    table.cell(tbl, 1, 16, "──────", text_color=color.new(color.white,70), text_size=TINY)

    table.cell(tbl, 0, 17, "Stop L",  text_color=DIM, text_size=SML)
    table.cell(tbl, 1, 17,
         not na(active_stop_long) ?
              str.tostring(active_stop_long, format.mintick) + " [" + grade_long + "]"
              : "—",
         text_color=not na(active_stop_long) ? i_c_stop : DIM, text_size=SML)

    table.cell(tbl, 0, 18, "Stop S",  text_color=DIM, text_size=SML)
    table.cell(tbl, 1, 18,
         not na(active_stop_short) ?
              str.tostring(active_stop_short, format.mintick) + " [" + grade_short + "]"
              : "—",
         text_color=not na(active_stop_short) ? i_c_stop : DIM, text_size=SML)

    table.cell(tbl, 0, 19, "Spot OK",  text_color=DIM, text_size=SML)
    table.cell(tbl, 1, 19,
         spot_caught_up ? "⚠ CLOSED" : "✓ OPEN",
         text_color=spot_caught_up ? color.new(color.red,0) : color.new(color.lime,0),
         text_size=SML)

// ════════════════════════════════════════════════════════════
// ── ALERTS
// ════════════════════════════════════════════════════════════
alertcondition(new_bull_a or new_bear_a,
     "ITPI v3 Grade A",
     "ITPI v3 — GRADE A: Treasury futures + FX futures + early all aligned. Maximum conviction.")

alertcondition(new_bull_b or new_bear_b,
     "ITPI v3 Grade B",
     "ITPI v3 — GRADE B: Treasury futures + FX futures both leading spot.")

alertcondition(new_bull_c or new_bear_c,
     "ITPI v3 Grade C",
     "ITPI v3 — GRADE C: Treasury futures leading (FX futures not yet). Earliest entry.")

alertcondition(new_bull_d or new_bear_d,
     "ITPI v3 Grade D",
     "ITPI v3 — GRADE D: FX futures leading spot (no treasury confirmation).")

alertcondition(new_bull,
     "ITPI v3 Long Signal",
     "ITPI v3 — LONG. Treasury futures and/or FX futures leading spot FX upward.")

alertcondition(new_bear,
     "ITPI v3 Short Signal",
     "ITPI v3 — SHORT. Treasury futures and/or FX futures leading spot FX downward.")

alertcondition(new_bull_a or new_bear_a or new_bull_b or new_bear_b,
     "ITPI v3 High Conviction (A or B)",
     "ITPI v3 — HIGH CONVICTION (Grade A or B). Both treasury and FX futures aligned.")
